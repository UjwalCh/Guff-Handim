# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173

# Database
DB_DIALECT=sqlite
SQLITE_STORAGE=./dev.sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=securechat
DB_USER=root
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-string-at-least-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
ADMIN_JWT_SECRET=change-this-admin-jwt-secret

# Admin Bootstrap (super admin)
ADMIN_USERNAME=owner
ADMIN_PASSWORD=ChangeMe!12345
ADMIN_PHONE=+10000000000

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Leave empty in dev to use console logging, fill for production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,mp4,mov,avi,mp3,ogg,wav,pdf,doc,docx,xls,xlsx,zip,txt

# Encryption
COOKIE_SECRET=another-long-random-secret-for-cookie-signing
